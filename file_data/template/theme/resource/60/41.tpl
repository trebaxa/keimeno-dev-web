<section class="person-card" role="region" aria-labelledby="person-heading-<%$resrc.var.fv_id%>">
  <div class="container">
    <h2 id="person-heading-<%$resrc.var.fv_id%>"><%$resrc.var.fv_name%></h2>
    <p><%$resrc.var.fv_funktion%></p>
    <img
      loading="lazy"
      alt="<%$resrc.var.fv_bild_alt%>"
      src="<%$resrc.var.fv_bild%>"
      <%$resrc.var.fv_bild_sizes%>
      role="img"
    >
  </div>
</section>